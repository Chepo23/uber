{
  "esquemas_sierra": {
    "descripcion": "Esquemas completos para pedidos Sierra - Extracción del archivo v1.json",
    "fecha_extraccion": "2026-04-20",
    "nota": "Todos los campos opcionales pueden ser null",
    
    "1_UploadDatav2": {
      "nombre_esquema": "UploadDatav2",
      "descripcion": "Wrapper principal - Información enviada para cargar ventas al servicio Sierra. Este es el esquema raíz que encapsula los datos de una venta completa.",
      "tipo": "object",
      "requeridos": ["salesDate"],
      "campos": {
        "status": {
          "tipo": "string | null",
          "requerido": false,
          "descripcion": "Estado de la carga."
        },
        "client": {
          "tipo": "string | null",
          "requerido": false,
          "descripcion": "Identificador del cliente."
        },
        "site": {
          "tipo": "string | null",
          "requerido": false,
          "descripcion": "Identificador del sitio."
        },
        "siteName": {
          "tipo": "string | null",
          "requerido": false,
          "descripcion": "Nombre del sitio."
        },
        "salesDate": {
          "tipo": "date-time",
          "requerido": true,
          "descripcion": "Fecha de las ventas (obligatorio)."
        },
        "data": {
          "tipo": "string | null",
          "requerido": false,
          "descripcion": "Datos de ventas serializados (generalmente contiene órdenes en formato JSON serializado)."
        },
        "ip": {
          "tipo": "string | null",
          "requerido": false,
          "descripcion": "Dirección IP del origen."
        },
        "guid": {
          "tipo": "string | null",
          "requerido": false,
          "descripcion": "Identificador único de la sesión."
        },
        "system": {
          "tipo": "string | null",
          "requerido": false,
          "descripcion": "Sistema de origen."
        },
        "clientData": {
          "tipo": "array[Client] | null",
          "requerido": false,
          "descripcion": "Datos adicionales del cliente (array de objetos Client)."
        }
      }
    },

    "2_Client": {
      "nombre_esquema": "Client",
      "descripcion": "Información básica del cliente/ubicación.",
      "tipo": "object",
      "requeridos": [],
      "campos": {
        "clientId": {
          "tipo": "integer",
          "requerido": false,
          "descripcion": "Identificador interno del cliente."
        },
        "fiscalName": {
          "tipo": "string | null",
          "requerido": false,
          "descripcion": "Razón social registrada."
        },
        "name": {
          "tipo": "string | null",
          "requerido": false,
          "descripcion": "Nombre comercial del cliente."
        },
        "rfc": {
          "tipo": "string | null",
          "requerido": false,
          "descripcion": "RFC del cliente."
        },
        "enabled": {
          "tipo": "integer (0 o 1)",
          "requerido": false,
          "descripcion": "Indica si el cliente está habilitado (0=no, 1=sí)."
        },
        "zone": {
          "tipo": "string | null",
          "requerido": false,
          "descripcion": "Zona geográfica asignada."
        },
        "office": {
          "tipo": "string | null",
          "requerido": false,
          "descripcion": "Oficina relacionada."
        },
        "debugMode": {
          "tipo": "integer (0 o 1)",
          "requerido": false,
          "descripcion": "Nivel de depuración para el sitio (0=desactivado, 1=activado)."
        },
        "enableStats": {
          "tipo": "integer (0 o 1)",
          "requerido": false,
          "descripcion": "Indica si se habilitan estadísticas (0=no, 1=sí)."
        },
        "enableDashboard": {
          "tipo": "integer (0 o 1)",
          "requerido": false,
          "descripcion": "Indica si se muestra el dashboard (0=no, 1=sí)."
        }
      }
    },

    "3_OrderTicket": {
      "nombre_esquema": "OrderTicket",
      "descripcion": "Datos completos de una orden/ticket. Este es el esquema que se envía dentro del campo 'data' de UploadDatav2 (usualmente serializado como JSON string).",
      "tipo": "object",
      "requeridos": ["order"],
      "campos": {
        "order": {
          "tipo": "string",
          "requerido": true,
          "descripcion": "Número de orden original (identificador único de la orden)."
        },
        "terminal": {
          "tipo": "string | null",
          "requerido": false,
          "descripcion": "Número de terminal/caja."
        },
        "server": {
          "tipo": "string | null",
          "requerido": false,
          "descripcion": "Mesero/vendedor asignado."
        },
        "cashier": {
          "tipo": "string | null",
          "requerido": false,
          "descripcion": "Cajero que registra la orden."
        },
        "subTotal": {
          "tipo": "decimal",
          "requerido": false,
          "descripcion": "Subtotal de la orden (sin impuestos)."
        },
        "tax": {
          "tipo": "decimal",
          "requerido": false,
          "descripcion": "IVA/Impuestos aplicados."
        },
        "credits": {
          "tipo": "decimal",
          "requerido": false,
          "descripcion": "Pagos/créditos aplicados."
        },
        "change": {
          "tipo": "decimal",
          "requerido": false,
          "descripcion": "Cambio entregado."
        },
        "salesType": {
          "tipo": "string | null",
          "requerido": false,
          "descripcion": "Tipo de venta según catálogo (ej: 'DINE_IN', 'TAKEOUT', 'DELIVERY')."
        },
        "orderType": {
          "tipo": "string | null",
          "requerido": false,
          "descripcion": "Tipo de orden según origen (ej: 'ORDEN WEB ONLINE', 'ORDEN WEB LOCAL')."
        },
        "openStatus": {
          "tipo": "string (0 o 1)",
          "requerido": false,
          "descripcion": "0 = Cuenta se cierra automáticamente, 1 = Cliente debe cerrar cuenta."
        },
        "production": {
          "tipo": "boolean",
          "requerido": false,
          "descripcion": "Indica si es ambiente de producción (true) o demo/pruebas (false)."
        },
        "routeProducts": {
          "tipo": "boolean",
          "requerido": false,
          "descripcion": "Enviar productos a cocina(s)/barra(s) para preparación."
        },
        "paymentTransactionId": {
          "tipo": "string | null",
          "requerido": false,
          "descripcion": "Folio de transacción de pago (Stripe u otro gateway)."
        },
        "orderComments": {
          "tipo": "string | null",
          "requerido": false,
          "descripcion": "Comentarios generales de la orden (se replica en todos los productos)."
        },
        "tableNumber": {
          "tipo": "string | null",
          "requerido": false,
          "descripcion": "Número de mesa (para órdenes locales/QR)."
        },
        "orderName": {
          "tipo": "string | null",
          "requerido": false,
          "descripcion": "Nombre identificador de la orden en el PDV (opcional)."
        },
        "client": {
          "tipo": "array[ClientOrder] | null",
          "requerido": false,
          "descripcion": "Datos del cliente (array con información de contacto y entrega)."
        },
        "plus": {
          "tipo": "array[PluOrder]",
          "requerido": false,
          "descripcion": "Lista de productos (items) en la orden."
        },
        "payments": {
          "tipo": "array[PaymentOrder] | null",
          "requerido": false,
          "descripcion": "Lista de pagos aplicados (opcional, detalle de métodos de pago)."
        },
        "paymentIdentifierString": {
          "tipo": "string | null",
          "requerido": false,
          "descripcion": "Nombre del método de pago para mostrar en PDV (opcional)."
        }
      }
    },

    "4_PluOrder": {
      "nombre_esquema": "PluOrder",
      "descripcion": "Detalle de cada producto en una orden. PLU = Price Look Up (código de artículo).",
      "tipo": "object",
      "requeridos": ["plu"],
      "campos": {
        "plu": {
          "tipo": "string",
          "requerido": true,
          "descripcion": "Número de PLU (código único del producto)."
