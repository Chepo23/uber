        },
        "unitPrice": {
          "tipo": "decimal",
          "requerido": false,
          "descripcion": "Precio unitario del producto."
        },
        "subTotal": {
          "tipo": "decimal",
          "requerido": false,
          "descripcion": "Subtotal (cantidad × precio unitario), sin impuestos."
        },
        "tax": {
          "tipo": "decimal",
          "requerido": false,
          "descripcion": "Impuesto total (IVA) sobre este producto."
        },
        "taxTable": {
          "tipo": "string | null",
          "requerido": false,
          "descripcion": "Identificador de tabla de impuestos aplicada (ej: 'IVA16', 'IVA0')."
        },
        "comments": {
          "tipo": "string | null",
          "requerido": false,
          "descripcion": "Comentarios/notas específicas para este producto (instrucciones de preparación)."
        },
        "subPlus": {
          "tipo": "array[SubPlus] | null",
          "requerido": false,
          "descripcion": "Modificadores/complementos del producto (extras, cambios, opciones)."
        }
      }
    },

