# Variables de entorno para el POS System

# API del Restaurante
VITE_API_URL=http://localhost:3001/api

# API de Uber Eats
VITE_UBER_API_URL=http://localhost:3002/api

# Token de autenticación para Uber Eats
VITE_UBER_AUTH_TOKEN=tu_token_de_autenticacion_aqui

# Sierra ERP API Configuration
VITE_SIERRA_API_URL=https://demo-services-alternative.sierraerp.com
VITE_SIERRA_API_KEY=YOUR_API_KEY_HERE

# (Opcional) Variables adicionales
VITE_APP_NAME=POS System Uber Eats
VITE_APP_VERSION=1.0.0
